  "profiles": {
    "basic-v1": {
      "title": "basic v1",
      "kind": "shared",
      "status": "stable",
      "based_on": [],
      "description": "Shared profile for the common serialization backbone: core format rules, primitive data types, and basic container encodings."
    },
    "basic-v2": {
      "title": "basic v2",
      "kind": "shared",
      "status": "draft",
      "based_on": [],
      "description": "Planned successor to `basic v1`. For now this profile is a draft placeholder for the next revision of the shared backbone, starting with the forthcoming change to boolean serialization."
    },
    "oscar-v1.5": {
      "title": "OSCAR v1.5",
      "kind": "application",
      "status": "stable",
      "based_on": [
        "basic-v1"
      ],
      "description": "Application profile for the OSCAR 1.5 serialization format. The current corpus shows that many examples were already supported, but some typed encodings were still less explicit than in OSCAR 1.6 and 1.7."
    },
    "oscar-v1.6": {
      "title": "OSCAR v1.6",
      "kind": "application",
      "status": "stable",
      "based_on": [
        "basic-v1"
      ],
      "description": "Application profile for the OSCAR 1.6 serialization format. In the current corpus this largely matches OSCAR 1.7, with the main documented differences appearing in matrix groups and a few type-level encodings that were finalized later."
    },
    "oscar-v1.7": {
      "title": "OSCAR v1.7",
      "kind": "application",
      "status": "stable",
      "based_on": [
        "basic-v1"
      ],
      "description": "Application profile for the OSCAR 1.7 serialization format. At present this extends `basic v1` with the OSCAR-specific algebraic, group-theoretic, Lie-theoretic, and polyhedral encodings documented by this prototype."
    },
    "oscar-v1.8": {
      "title": "OSCAR v1.8",
      "kind": "application",
      "status": "draft",
      "based_on": [
        "basic-v2"
      ],
      "description": "Draft application profile for the OSCAR 1.8 serialization format. It is intended to track the next shared backbone revision via `basic v2`; later revisions can make its divergences from OSCAR 1.7 explicit."
    }
  }
}
